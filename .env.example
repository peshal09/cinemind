# Copy to .env and adjust as needed. .env is gitignored.

# PostgreSQL connection used by SQLAlchemy.
DATABASE_URL=postgresql+psycopg2://cinemind:cinemind@127.0.0.1:5432/cinemind

# JWT auth. Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis cache
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL_SECONDS=60

# CORS: comma-separated allowed origins for the frontend, e.g.
#   http://localhost:5500,http://127.0.0.1:5500
# Use "*" to allow any origin (fine for local dev since we use bearer tokens).
CORS_ORIGINS=*

# TMDB (themoviedb.org) v3 API key for metadata enrichment.
TMDB_API_KEY=your-tmdb-v3-api-key

# LLM provider for the RAG /ask endpoint. (Gemini free tier by default.)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
ASK_MAX_TOKENS=1024
# Min retrieval cosine similarity before calling the LLM (groundedness guard).
# Model-dependent: ~0.83 for gte-small embeddings (scores run high), ~0.30 for
# the older all-MiniLM-L6-v2.
ASK_SIMILARITY_THRESHOLD=0.83
